; eslint-plugin-jsx-a11y@6.10.2 declares peer eslint "<=9" but the project
; runs eslint 10. Upstream ESLint 10 support is still in-flight (see
; jsx-eslint/eslint-plugin-jsx-a11y#1079, #1081). Keeping legacy-peer-deps
; on lets `npm ci` succeed both locally and in CI without per-workflow
; flag drift. Revisit once jsx-a11y publishes a release with eslint@^10
; in its peerDependencies range. See ADR-0018.
legacy-peer-deps=true
