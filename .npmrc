; pnpm config — see ADR-0019 for the npm → pnpm migration.
;
; eslint-plugin-jsx-a11y@6.10.2 declares peer eslint "<=9" but the project
; runs eslint 10. Upstream ESLint 10 support is still in-flight (see
; jsx-eslint/eslint-plugin-jsx-a11y#1079, #1081). The two flags below are
; the pnpm equivalents of npm's `legacy-peer-deps=true`: pnpm installs
; missing peers automatically and does not hard-fail on peer-range
; mismatches. Revisit once jsx-a11y publishes a release with eslint@^10
; in its peerDependencies range. See ADR-0018.
auto-install-peers=true
strict-peer-dependencies=false
