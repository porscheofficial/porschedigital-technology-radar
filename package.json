{
  "name": "porschedigital-technology-radar",
  "private": true,
  "version": "1.0.0",
  "bin": {
    "techradar": "./dist/bin/techradar.js"
  },
  "scripts": {
    "dev": "portless run next dev",
    "build:icons": "npx @svgr/cli --typescript --no-dimensions --no-prettier --out-dir src/components/Icons -- src/icons",
    "build:data": "tsx scripts/buildData.ts",
    "validate": "tsx scripts/validateFrontmatter.ts",
    "build:bin": "tsup",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "prepare": "(husky || true) && npm run build:bin",
    "postinstall": "npm run build:icons"
  },
  "devDependencies": {
    "@11ty/gray-matter": "^2.0.1",
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "hast": "^0.0.2",
    "husky": "^9.0.11",
    "jsdom": "^29.0.2",
    "knip": "6.4.0",
    "lint-staged": "^15.2.7",
    "markdownlint-cli2": "^0.22.0",
    "next": "^16.2.3",
    "portless": "^0.10.1",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.15.8",
    "typescript": "^5",
    "unified": "^11.0.5",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@porsche-design-system/components-react": "^3.33.0",
    "sass": "^1.99.0"
  },
  "lint-staged": {
    "**/*": "biome check --write --no-errors-on-unmatched"
  }
}
