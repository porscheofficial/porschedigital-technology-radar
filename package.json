{
  "name": "@porscheofficial/porschedigital-technology-radar",
  "private": true,
  "version": "1.0.0",
  "bin": {
    "techradar": "./bin/techradar.js"
  },
  "scripts": {
    "dev": "portless run next dev",
    "build:icons": "npx @svgr/cli --typescript --no-dimensions --no-prettier --out-dir src/components/Icons -- src/icons",
    "build:data": "tsx scripts/buildData.ts",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "postinstall": "npm run build:icons"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "3.6.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "husky": "^9.0.11",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.7",
    "marked": "^13.0.1",
    "marked-highlight": "^2.1.3",
    "next": "^16.2.3",
    "portless": "^0.10.1",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.15.8",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@porsche-design-system/components-react": "^3.33.0",
    "sass": "^1.99.0"
  },
  "lint-staged": {
    "**/*": "biome check --write --no-errors-on-unmatched"
  }
}
