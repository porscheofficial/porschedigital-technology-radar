{
  "name": "porschedigital-technology-radar-workspace",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "check:arch": "pnpm -r --if-present run check:arch",
    "check:sec": "pnpm -r --if-present run check:sec && pnpm run check:sec:deps && pnpm run check:sec:secrets && pnpm run check:sec:licenses",
    "check:sec:deps": "osv-scanner --lockfile=pnpm-lock.yaml",
    "check:sec:secrets": "trufflehog git file://. --no-update --fail --results=verified,unknown",
    "check:sec:licenses": "pnpm run check:sec:licenses:techradar && pnpm run check:sec:licenses:scaffolder",
    "check:sec:licenses:techradar": "license-checker-rseidelsohn --start packages/techradar --production --failOn 'GPL;AGPL;LGPL;SSPL;BUSL;CC-BY-NC'",
    "check:sec:licenses:scaffolder": "license-checker-rseidelsohn --start packages/create-techradar --production --failOn 'GPL;AGPL;LGPL;SSPL;BUSL;CC-BY-NC'",
    "check:quality": "pnpm -r --if-present run check:quality",
    "check:a11y": "pnpm -r --if-present run check:a11y",
    "check:build": "pnpm -r --if-present run check:build",
    "precommit:secrets": "pnpm --filter @porscheofficial/porschedigital-technology-radar run precommit:secrets",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.0.11",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^15.2.7"
  },
  "lint-staged": {
    "**/*": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ],
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
