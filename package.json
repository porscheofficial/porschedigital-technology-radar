{
  "name": "@porscheofficial/porschedigital-technology-radar",
  "version": "1.0.4",
  "description": "Static site generator for building and publishing your own Technology Radar.",
  "keywords": [
    "technology-radar",
    "tech-radar",
    "thoughtworks",
    "static-site",
    "next.js",
    "porsche"
  ],
  "license": "Apache-2.0",
  "author": "Porsche Digital",
  "homepage": "https://opensource.porsche.com/porschedigital-technology-radar/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/porscheofficial/porschedigital-technology-radar.git"
  },
  "bugs": {
    "url": "https://github.com/porscheofficial/porschedigital-technology-radar/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "techradar": "dist/bin/techradar.js"
  },
  "files": [
    "dist",
    "bin",
    "data",
    "public",
    "scripts",
    "src",
    "next.config.js",
    "next-env.d.ts",
    "tsconfig.json",
    "biome.jsonc",
    "postcss.config.js",
    ".markdownlint-cli2.jsonc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "portless run next dev",
    "build:icons": "npx @svgr/cli --typescript --no-dimensions --no-prettier --out-dir src/components/Icons -- src/icons",
    "build:data": "tsx scripts/buildData.ts",
    "validate": "tsx scripts/validateFrontmatter.ts",
    "build:bin": "tsup",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:arch": "npm run check:arch:depcruise && npm run check:arch:eslint && npm run check:arch:readme && npm run check:arch:doccoverage",
    "check:arch:depcruise": "depcruise --config .dependency-cruiser.cjs src scripts",
    "check:arch:eslint": "eslint .",
    "check:arch:readme": "tsx scripts/checkConfigReadmeSync.ts",
    "check:arch:doccoverage": "tsx scripts/checkDocCoverage.ts",
    "check:build": "npm run check:build:routes && npm run check:build:links && npm run check:build:budget",
    "check:build:routes": "tsx scripts/checkBuildOutput.ts",
    "check:build:links": "linkinator ./out/index.html --config linkinator.config.json",
    "check:build:budget": "tsx scripts/checkBundleBudget.ts",
    "check:sec": "npm run check:sec:sanitize && npm run check:sec:deps && npm run check:sec:secrets",
    "check:sec:sanitize": "tsx scripts/checkSanitize.ts",
    "check:sec:deps": "osv-scanner --lockfile=package-lock.json",
    "check:sec:secrets": "gitleaks detect --no-git -s .",
    "check:quality": "npm run check:quality:knip && npm run check:quality:jscpd && npm run check:quality:naming",
    "check:quality:knip": "knip",
    "check:quality:jscpd": "jscpd",
    "check:quality:naming": "biome lint --only=style/useNamingConvention --diagnostic-level=error src scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "(husky || true) && npm run build:icons && npm run build:bin"
  },
  "devDependencies": {
    "@11ty/gray-matter": "^2.0.1",
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "execa": "^9.6.1",
    "hast": "^1.0.0",
    "husky": "^9.0.11",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.2",
    "knip": "6.4.0",
    "linkinator": "^7.6.1",
    "lint-staged": "^15.2.7",
    "markdownlint-cli2": "^0.21.0",
    "next": "^16.2.3",
    "portless": "^0.10.1",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.15.8",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "unified": "^11.0.5",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@porsche-design-system/components-react": "^3.33.0",
    "sass": "^1.99.0"
  },
  "lint-staged": {
    "**/*": "biome check --write --no-errors-on-unmatched"
  }
}
