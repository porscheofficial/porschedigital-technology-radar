{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["scripts/*.ts"],
  "project": ["src/**/*.{ts,tsx}", "bin/**/*.{ts,js}", "scripts/**/*.ts"],
  "ignore": ["src/components/Icons/index.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["trufflehog", "biome", "ffmpeg", "img2webp"],
  "ignoreDependencies": [
    "html-validate",
    "@fontsource/inter",
    "@porsche-design-system/components-js"
  ]
}
