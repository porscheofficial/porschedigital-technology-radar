{
  "name": "@porscheofficial/porschedigital-technology-radar",
  "version": "2.1.0",
  "description": "Static site generator for building and publishing your own Technology Radar.",
  "keywords": [
    "technology-radar",
    "tech-radar",
    "thoughtworks",
    "static-site",
    "next.js",
    "porsche"
  ],
  "license": "Apache-2.0",
  "author": "Porsche Digital",
  "homepage": "https://opensource.porsche.com/porschedigital-technology-radar/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/porscheofficial/porschedigital-technology-radar.git",
    "directory": "packages/techradar"
  },
  "bugs": {
    "url": "https://github.com/porscheofficial/porschedigital-technology-radar/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "techradar": "dist/bin/techradar.js"
  },
  "files": [
    "dist",
    "bin",
    "data",
    "public",
    "scripts",
    "src",
    "LICENSE",
    "next.config.js",
    "next-env.d.ts",
    "tsconfig.json",
    "postcss.config.js",
    ".markdownlint-cli2.jsonc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build:icons": "pnpm dlx @svgr/cli --typescript --no-dimensions --no-prettier --out-dir src/components/Icons -- src/icons",
    "build:data": "tsx scripts/buildThemes.ts && tsx scripts/buildData.ts",
    "build:og": "tsx scripts/buildOgImages.ts",
    "validate": "tsx scripts/validateFrontmatter.ts",
    "build:bin": "tsup",
    "build": "tsx scripts/buildData.ts && tsx scripts/buildOgImages.ts && next build",
    "start": "next start",
    "record:demo": "tsx scripts/recordDemo.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:arch": "pnpm run check:arch:depcruise && pnpm run check:arch:eslint && pnpm run check:arch:readme && pnpm run check:arch:doccoverage && pnpm run check:arch:wikilinks && pnpm run check:arch:adr && pnpm run check:arch:version-literals",
    "check:arch:depcruise": "depcruise --config .dependency-cruiser.cjs src scripts",
    "check:arch:eslint": "eslint .",
    "check:arch:readme": "tsx scripts/checkConfigReadmeSync.ts",
    "check:arch:doccoverage": "tsx scripts/checkDocCoverage.ts ../..",
    "check:arch:wikilinks": "tsx scripts/checkWikiLinks.ts",
    "check:arch:adr": "tsx scripts/checkAdrUnique.ts ../../docs/decisions",
    "check:arch:version-literals": "tsx scripts/check-version-literals.ts",
    "check:build": "pnpm run check:build:routes && pnpm run check:build:links && pnpm run check:build:budget && pnpm run check:build:html && pnpm run check:build:no-node-builtins && pnpm run check:build:bundle-budget",
    "check:build:routes": "tsx scripts/checkBuildOutput.ts",
    "check:build:links": "linkinator ./out/index.html --config linkinator.config.json",
    "check:build:budget": "tsx scripts/checkBundleBudget.ts",
    "check:build:html": "tsx scripts/checkHtmlValidate.ts",
    "check:build:no-node-builtins": "tsx scripts/checkNoNodeBuiltins.ts",
    "check:build:bundle-budget": "tsx scripts/check-bundle-budget.ts",
    "check:sec": "pnpm run check:sec:sanitize",
    "check:sec:sanitize": "tsx scripts/checkSanitize.ts",
    "check:sec:secrets": "tsx scripts/checkSecrets.ts",
    "precommit:secrets": "tsx scripts/preCommitSecrets.ts",
    "check:quality": "pnpm run check:quality:knip && pnpm run check:quality:jscpd && pnpm run check:quality:naming && pnpm run check:quality:sonar && pnpm run check:quality:coverage && pnpm run check:quality:spell",
    "check:quality:knip": "knip",
    "check:quality:jscpd": "jscpd",
    "check:quality:naming": "biome lint --only=style/useNamingConvention --diagnostic-level=error src scripts",
    "check:quality:sonar": "eslint --config sonar.eslint.config.mjs src scripts bin",
    "check:quality:coverage": "vitest run --coverage",
    "check:quality:spell": "cspell --no-progress --no-summary --no-must-find-files '**/*.md'",
    "check:a11y": "pnpm run check:a11y:source && pnpm run check:a11y:axe",
    "check:a11y:source": "eslint --config a11y.eslint.config.mjs src",
    "check:a11y:axe": "tsx scripts/checkA11y.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "pnpm run build:icons && pnpm run build:bin",
    "postinstall": "node -e \"process.exit(require('node:fs').existsSync('data/data.json') ? 0 : 1)\" || pnpm run build:data"
  },
  "dependencies": {
    "@11ty/gray-matter": "^2.0.1",
    "@fontsource/inter": "^5.2.8",
    "@porsche-design-system/components-js": "4.1.0",
    "@porsche-design-system/components-react": "^4.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@resvg/resvg-js": "^2.6.2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "html-react-parser": "^6.0.1",
    "jsonc-parser": "^3.3.1",
    "next": "^16.2.6",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sass": "^1.99.0",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "unified": "^11.0.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.4",
    "cspell": "^10.0.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "html-validate": "^10.16.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.1.1",
    "knip": "6.9.0",
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.22.1",
    "playwright": "^1.50.0",
    "portless": "^0.12.0",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
