{
  "extends": "./packages/techradar/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/techradar/src/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "packages/techradar/next-env.d.ts",
    "packages/techradar/**/*.ts",
    "packages/techradar/**/*.tsx",
    "packages/techradar/.next/types/**/*.ts",
    "packages/techradar/.next/dev/types/**/*.ts",
    "packages/create-techradar/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules",
    "packages/*/dist/**",
    "packages/*/coverage/**",
    "packages/techradar/src/components/Icons/**"
  ]
}
